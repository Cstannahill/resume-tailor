PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://user:password@localhost:5432/experience"

# LLM Providers
DEFAULT_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=replace-me

BEDROCK_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

GOOGLE_GENAI_API_KEY=replace-me

OPENROUTER_API_KEY=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Auth & Encryption
AUTH_JWT_SECRET=replace-with-strong-secret
APP_ENCRYPTION_KEY=base64-encoded-32-bytes

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
